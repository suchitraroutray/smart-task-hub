# Database Configuration
DATABASE_URL=sqlite:///./booking_system.db

# CORS Configuration
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Demo Data Seeding
SEED_DEMO_DATA=true

# Power BI API Configuration
# Get these from Azure AD App Registration
POWERBI_TENANT_ID=your-tenant-id-here
POWERBI_CLIENT_ID=your-client-id-here
POWERBI_CLIENT_SECRET=your-client-secret-here

# Power BI Workspace IDs (comma-separated for multiple workspaces)
POWERBI_WORKSPACE_IDS=workspace-id-1,workspace-id-2

# Automation Settings
POWERBI_CHECK_INTERVAL_MINUTES=15
POWERBI_SLOW_REFRESH_THRESHOLD_MINUTES=30

# Java Service Configuration (if using hold service)
JAVA_SERVICE_URL=http://localhost:8080